<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 背景图复用 bg2 -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg2"
        android:scaleType="centerCrop"
        android:contentDescription="background"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#BB000000"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏪 金币商店"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"/>

        <!-- 当前金币 -->
        <TextView
            android:id="@+id/tv_coin_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 金币：0"
            android:textSize="22sp"
            android:textColor="#FFD700"
            android:layout_marginBottom="32dp"/>

        <!-- 护盾道具 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#1E1E2E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️ 开局护盾"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本局开始时英雄获得一次无敌保护，承受一次致命伤害后消失"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btn_buy_shield"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="开局护盾  100金币（库存:0）"
                    android:backgroundTint="#1565C0"
                    android:textColor="@android:color/white"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 双倍火力道具 -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#1E1E2E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 开局双倍火力"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本局开始时英雄火力加倍，持续30秒"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btn_buy_double_gun"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="双倍火力  150金币（库存:0）"
                    android:backgroundTint="#FF6600"
                    android:textColor="@android:color/white"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_back_shop"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="返回"
            android:textSize="18sp"
            android:backgroundTint="#444444"
            android:textColor="@android:color/white"/>

    </LinearLayout>
</FrameLayout>