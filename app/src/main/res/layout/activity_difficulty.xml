<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 背景图 bg2.jpg，放在 res/drawable/ -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg2"
        android:scaleType="centerCrop"
        android:contentDescription="background"/>

    <!-- 半透明遮罩，让按钮更清晰 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"/>

    <!-- 内容区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_title"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginBottom="36dp"/>

        <Button
            android:id="@+id/btn_easy"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="@string/easy_mode"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_normal"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="@string/normal_mode"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_hard"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="@string/hard_mode"
            android:textSize="20sp"
            android:layout_marginBottom="24dp"/>

        <!-- 分割线 -->
        <View
            android:layout_width="200dp"
            android:layout_height="1dp"
            android:background="#555555"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_multiplayer"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="联机对战"
            android:textSize="20sp"
            android:backgroundTint="#FF6600"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_rank"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="排行榜"
            android:textSize="20sp"
            android:backgroundTint="#1565C0"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"/>

        <!-- 金币商店按钮 -->
        <Button
            android:id="@+id/btn_shop"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="🏪 金币商店"
            android:textSize="18sp"
            android:backgroundTint="#2E7D32"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp"/>

        <!-- 音乐开关 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/music_sound_label"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginEnd="16dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_music"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>